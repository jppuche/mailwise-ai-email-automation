# ============================================================
# mailwise — Environment Variables
# Copy this file to .env and fill in actual values.
# .env is gitignored — never commit real secrets.
# ============================================================

# --- Database ---
# Async URL for FastAPI (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://mailwise:password@db:5432/mailwise
# Sync URL for Celery tasks (psycopg2 driver)
DATABASE_URL_SYNC=postgresql+psycopg2://mailwise:password@db:5432/mailwise

# PostgreSQL service credentials (used by docker-compose db service)
POSTGRES_USER=mailwise
POSTGRES_PASSWORD=password
POSTGRES_DB=mailwise

# --- Redis ---
# Default: redis://redis:6379/0
REDIS_URL=redis://redis:6379/0
# Redis password — must match REDIS_PASSWORD used in docker-compose.yml.
# Format with auth: redis://:password@redis:6379/0
REDIS_PASSWORD=mailwise_redis

# --- JWT ---
# REQUIRED — generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
# Default: HS256
JWT_ALGORITHM=HS256
# Default: 15 (minutes). Too long: security risk if token leaked. Too short: frequent re-auth.
JWT_ACCESS_TTL_MINUTES=15
# Default: 7 (days). Affects session persistence.
JWT_REFRESH_TTL_DAYS=7

# --- Security ---
# Default: 12. Too low: passwords brute-forceable. Too high: login >1s.
BCRYPT_ROUNDS=12
# Default: ["http://localhost:5173"]. JSON array format. REQUIRED in production — no safe default.
CORS_ORIGINS=["http://localhost:5173"]

# --- Pipeline Defaults (Cat 8 — all load-bearing) ---
# Default: 300 (5 min). Too low: Gmail rate limit. Too high: emails delayed.
POLLING_INTERVAL_SECONDS=300
# Default: 50. Too high: LLM timeout. Too low: throughput loss.
INGESTION_BATCH_SIZE=50
# Default: 4000. Too low: LLM loses context. Too high: LLM cost/latency.
MAX_BODY_LENGTH=4000
# Default: 200. Affects UI previews and log size.
SNIPPET_LENGTH=200
# Default: 90. Affects compliance and storage costs.
DATA_RETENTION_DAYS=90

# --- LLM ---
# Default: gpt-4o-mini. Cheaper model for classification (temp 0.1).
LLM_MODEL_CLASSIFY=gpt-4o-mini
# Default: gpt-4o. More capable model for draft generation (temp 0.7).
LLM_MODEL_DRAFT=gpt-4o
# Default: 0.1. High temp: inconsistent classifications.
LLM_TEMPERATURE_CLASSIFY=0.1
# Default: 0.7. Low temp: robotic drafts.
LLM_TEMPERATURE_DRAFT=0.7
# API keys — leave empty if not using that provider
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Default: gpt-3.5-turbo. Fallback model — must differ from classify model.
LLM_FALLBACK_MODEL=gpt-3.5-turbo
# Default: 30 (seconds). LLM request timeout.
LLM_TIMEOUT_SECONDS=30
# Default: 500. Max tokens for classification response.
LLM_CLASSIFY_MAX_TOKENS=500
# Default: 2000. Max tokens for draft generation response.
LLM_DRAFT_MAX_TOKENS=2000
# Default: "" (empty). Custom LLM base URL for self-hosted models (e.g., Ollama).
LLM_BASE_URL=
# Default: "" (empty = use configured models). Comma-separated allowlist of permitted LLM model names.
# Example: gpt-4o-mini,gpt-4o,gpt-3.5-turbo
# When set, any model outside this list raises ValueError before calling the LLM provider.
LLM_ALLOWED_MODELS=

# --- Ingestion Lock ---
# Default: 300. TTL for ingestion lock in seconds.
INGESTION_LOCK_TTL_SECONDS=300
# Default: mailwise:ingest:lock. Redis key prefix for ingestion locks.
INGESTION_LOCK_KEY_PREFIX=mailwise:ingest:lock

# --- Classification ---
# Default: 10. Max few-shot examples included in classification prompt.
CLASSIFY_MAX_FEW_SHOT_EXAMPLES=10
# Default: 200. Chars of feedback snippet included in classification context.
CLASSIFY_FEEDBACK_SNIPPET_CHARS=200
# Default: "" (empty). Comma-separated internal email domains for heuristic classification.
CLASSIFY_INTERNAL_DOMAINS=

# --- Celery ---
# Default: 3. Too low: transient failures become permanent. Too high: queues saturated.
CELERY_MAX_RETRIES=3
# Default: 60 (seconds). Aggressive backoff may saturate services during recovery.
CELERY_BACKOFF_BASE=60
# Default: redis://redis:6379/0. Celery broker URL.
CELERY_BROKER_URL=redis://redis:6379/0
# Default: redis://redis:6379/1. Celery result backend URL.
CELERY_RESULT_BACKEND=redis://redis:6379/1
# Default: 3600 (1 hour). TTL for task results in seconds.
CELERY_RESULT_EXPIRES=3600

# --- Pipeline & Scheduler ---
# Default: mailwise:scheduler:lock. Redis key prefix for scheduler lock.
PIPELINE_SCHEDULER_LOCK_KEY_PREFIX=mailwise:scheduler:lock
# Default: 300. TTL for scheduler lock in seconds. Must be >= POLLING_INTERVAL_SECONDS.
PIPELINE_SCHEDULER_LOCK_TTL_SECONDS=300

# --- Gmail OAuth ---
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# Default: http://localhost:8000/api/v1/auth/gmail/callback
GMAIL_REDIRECT_URI=http://localhost:8000/api/v1/auth/gmail/callback
# Default: 100. Max messages per Gmail API fetch.
GMAIL_MAX_RESULTS=100
# Default: secrets/gmail_credentials.json. Path to Gmail OAuth credentials file.
GMAIL_CREDENTIALS_FILE=secrets/gmail_credentials.json
# Default: secrets/gmail_token.json. Path to Gmail OAuth token file.
GMAIL_TOKEN_FILE=secrets/gmail_token.json

# --- Slack ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# --- Channel Adapter ---
# Default: 150. Snippet length for Slack notifications.
CHANNEL_SNIPPET_LENGTH=150
# Default: 100. Max subject length in channel messages.
CHANNEL_SUBJECT_MAX_LENGTH=100
# Default: 10 (seconds). Slack API call timeout.
CHANNEL_SLACK_TIMEOUT_SECONDS=10
# Default: 200. Page size for channel destination listing.
CHANNEL_DESTINATIONS_PAGE_SIZE=200

# --- Routing ---
# Default: "" (empty). Comma-separated VIP sender addresses for priority routing.
ROUTING_VIP_SENDERS=
# Default: http://localhost:3000. Base URL for dashboard links in notifications.
ROUTING_DASHBOARD_BASE_URL=http://localhost:3000
# Default: 150. Snippet length in routing notifications.
ROUTING_SNIPPET_LENGTH=150

# --- HubSpot ---
HUBSPOT_ACCESS_TOKEN=
# Default: 100. Max HubSpot API requests per 10-second window.
HUBSPOT_RATE_LIMIT_PER_10S=100
# Default: 200. Snippet length for HubSpot activity logging.
HUBSPOT_ACTIVITY_SNIPPET_LENGTH=200
# Default: false. Auto-create HubSpot contacts for unknown senders.
HUBSPOT_AUTO_CREATE_CONTACTS=false
# Default: NEW. Default lead status for auto-created HubSpot contacts.
HUBSPOT_DEFAULT_LEAD_STATUS=NEW
# Default: 15 (seconds). HubSpot API call timeout.
HUBSPOT_API_TIMEOUT_SECONDS=15

# --- CRM Sync ---
# Default: 3. Max retries for CRM sync operations.
CRM_SYNC_RETRY_MAX=3
# Default: 60 (seconds). Backoff base for CRM sync retries.
CRM_SYNC_BACKOFF_BASE_SECONDS=60

# --- Draft Generation ---
# Default: false. Push generated drafts to Gmail (requires gmail.compose scope).
DRAFT_PUSH_TO_GMAIL=false
# Default: "" (empty). Organization-specific system prompt for draft generation.
DRAFT_ORG_SYSTEM_PROMPT=
# Default: professional. Tone for generated drafts (professional, friendly, formal).
DRAFT_ORG_TONE=professional
# Default: "" (empty). Organization email signature appended to drafts.
DRAFT_ORG_SIGNATURE=
# Default: "" (empty). Comma-separated prohibited language patterns.
DRAFT_ORG_PROHIBITED_LANGUAGE=
# Default: 2. Max retries for draft generation.
DRAFT_GENERATION_RETRY_MAX=2

# --- API ---
# Default: 200 (ms). Timeout for adapter health check probes.
API_HEALTH_ADAPTER_TIMEOUT_MS=200
# Default: 0.1.0. Application version reported in /api/v1/health.
APP_VERSION=0.1.0

# --- Analytics ---
# Default: 365. Max date range in days for analytics queries.
ANALYTICS_MAX_DATE_RANGE_DAYS=365
# Default: 1000. Chunk size for CSV streaming exports.
ANALYTICS_CSV_CHUNK_SIZE=1000
# Default: UTC. Default timezone for analytics date aggregation.
ANALYTICS_DEFAULT_TIMEZONE=UTC

# --- Logging ---
# Default: INFO. Log level (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO
# Default: json. Log format — json for production, text for local development.
LOG_FORMAT=text

# --- Docker Health Checks (used in docker-compose.yml) ---
# Default: 30s. Interval between health check probes.
HEALTHCHECK_INTERVAL=30s
# Default: 10s. Timeout for each health check probe.
HEALTHCHECK_TIMEOUT=10s
# Default: 3. Number of consecutive failures before marking unhealthy.
HEALTHCHECK_RETRIES=3
# Default: 60s. Grace period before health check failures count.
HEALTHCHECK_START_PERIOD=60s
